main {
    typedef Point: struct {
        x: int;
        y: int;
    };

    typedef Quadrilatere: tab[0..3] of Point;

    var carre:Quadrilatere;

    carre[0].x = 0;
    carre[0].y = 0;
    carre[1].x = 2;
    carre[1].y = 0;
    carre[2].x = 2;
    carre[2].y = 2;
    carre[3].x = 0;
    carre[3].y = 2;
}