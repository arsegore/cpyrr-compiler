main {
    var n: int;
    var resultat: int;

    int fct fibonacci(limite: int) {
        var a: int;
        var b: int;
        var i: int;
        var tmp: int;

        a = 0;
        b = 1; 
        i = 2;

        if (limite == 0) then {
            ret a;
        }

        if (limite == 1) then {
            ret b;
        }

        while (i <= limite) do {
            tmp = a + b;
            b = tmp;
            i = i + 1;
        }

        ret b;
    }

    n = 10;
    resultat = fibonacci(n);
}